{
  "name": "uibee",
  "version": "3.0.0",
  "description": "Shared components, functions and hooks for reuse across Login projects",
  "homepage": "https://github.com/Login-Linjeforening-for-IT/uibee#readme",
  "bugs": {
    "url": "https://github.com/Login-Linjeforening-for-IT/uibee/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Login-Linjeforening-for-IT/uibee.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    "./hooks": "./dist/src/hooks/index.js",
    "./components": "./dist/src/components/index.js",
    "./utils": "./dist/src/utils/index.js",
    "./styles": "./dist/src/styles/index.js",
    "./icons": "./dist/src/icons/index.js"
  },
  "scripts": {
    "build:css": "bun src/scripts/buildCss.ts && mkdir -p dist/src/styles && echo \"import '../globals.css';\" > dist/src/styles/index.js && echo \"export {};\" > dist/src/styles/index.d.ts",
    "build": "tsdown && bun run build:css",
    "dev": "tsdown --watch",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src"
  },
  "peerDependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tsdown/css": "^0.22.3",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "glob": "^13.0.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "utilbee": "^1.4.7"
  }
}