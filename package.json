{
  "name": "uibee",
  "version": "2.15.0",
  "description": "Shared components, functions and hooks for reuse across Login projects",
  "homepage": "https://github.com/Login-Linjeforening-for-IT/uibee#readme",
  "bugs": {
    "url": "https://github.com/Login-Linjeforening-for-IT/uibee/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Login-Linjeforening-for-IT/uibee.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    "./hooks": "./dist/src/hooks/index.js",
    "./components": "./dist/src/components/index.js",
    "./scripts": "./dist/src/scripts/index.js",
    "./utils": "./dist/src/utils/index.js",
    "./styles": "./dist/src/styles/index.js"
  },
  "scripts": {
    "build:clean": "rm -rf dist",
    "build:css": "node --loader ts-node/esm src/scripts/buildCss.ts",
    "build:rewrite": "node dist/src/scripts/rewriteAlias.js",
    "build:ts": "tsc --declaration",
    "build": "npm run build:clean && npm run build:css && npm run build:ts && npm run build:rewrite",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src"
  },
  "peerDependencies": {
    "next": "^16.1.6",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "glob": "^13.0.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "utilbee": "^1.4.1"
  }
}
